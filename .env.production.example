# Copy to .env on the EC2 server before: docker compose -f docker-compose.prod.yml up -d --build

# Public host (EC2 IP or domain) — used for TLS cert CN and CORS
SERVER_NAME=3.109.105.8

# Database
DB_PASSWORD=change-this-strong-db-password

# JWT — use a long random string (256-bit+)
JWT_SECRET=change-this-to-a-256-bit-secret-key-in-production

# Google Maps
GOOGLE_MAPS_API_KEY=
VITE_GOOGLE_MAPS_API_KEY=
VITE_GOOGLE_GEOCODING_API_KEY=
VITE_GOOGLE_PLACES_API_KEY=

# CORS (HTTPS origin — same as SERVER_NAME with https://)
CORS_ALLOWED_ORIGINS=https://3.109.105.8

# Email (disable in prod until SMTP is configured)
MAIL_ENABLED=false
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SMTP_AUTH=true
MAIL_STARTTLS=true
MAIL_FROM_NAME=Blood Donors
