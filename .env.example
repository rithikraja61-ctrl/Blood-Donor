# Copy this file to .env and adjust values, then run: docker compose up -d

# --- Google Maps ---
GOOGLE_MAPS_API_KEY=your-geocoding-places-api-key
VITE_GOOGLE_MAPS_API_KEY=your-maps-javascript-api-key
VITE_GOOGLE_GEOCODING_API_KEY=your-geocoding-browser-key
VITE_GOOGLE_PLACES_API_KEY=your-places-key

# --- Email Option 1: MailHog (local — open http://localhost:8025) ---
MAIL_ENABLED=true
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SMTP_AUTH=false
MAIL_STARTTLS=false
MAIL_FROM_NAME=Blood Donors

# --- Email Option 2: Real Gmail ---
# MAIL_ENABLED=true
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=your-email@gmail.com
# MAIL_PASSWORD=your16charapppassword
# MAIL_SMTP_AUTH=true
# MAIL_STARTTLS=true
# MAIL_FROM_NAME=Blood Donors
